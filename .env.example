# Docker Compose installation profile
POSTGRES_USER=chat_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=chat

NODE_ENV=production
PUBLIC_HOST=localhost
PUBLIC_URL=https://localhost
ALLOWED_ORIGINS=https://localhost

CLIENT_HTTP_BIND=0.0.0.0
CLIENT_HTTP_PORT=80
CLIENT_HTTPS_BIND=0.0.0.0
CLIENT_HTTPS_PORT=443

SERVER_BIND=127.0.0.1
SERVER_PORT=3000

POSTGRES_BIND=127.0.0.1
POSTGRES_PORT=5432

TLS_CERT_PATH=/etc/nginx/certs/server.crt
TLS_KEY_PATH=/etc/nginx/certs/server.key
TLS_ALT_NAMES=DNS:localhost,IP:127.0.0.1
RESTART_POLICY=unless-stopped
