{
	http_port {$CLIENT_HTTP_PORT}
	https_port {$CLIENT_HTTPS_PORT}
	auto_https disable_redirects
	servers :{$CLIENT_HTTPS_PORT} {
		listener_wrappers {
			http_redirect
			tls
		}
	}
}

http:// {
	@health path /healthz
	respond @health "ok" 200
	redir {$PUBLIC_URL}{uri} permanent
}

{$PUBLIC_HOST} {
	encode zstd gzip

	@health path /healthz
	respond @health "ok" 200

	@backend path /api* /auth/* /ws
	handle @backend {
		reverse_proxy server:3000
	}

	handle {
		header {
			Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
			Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob:; connect-src 'self' https: wss:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'"
			Referrer-Policy "strict-origin-when-cross-origin"
			X-Content-Type-Options "nosniff"
		}
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
