{$PUBLIC_HOST} {
	encode zstd gzip

	@health path /healthz
	respond @health "ok" 200

	@backend path /api* /auth/* /ws
	handle @backend {
		reverse_proxy server:3000
	}

	handle {
		header {
			Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
		}
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
